# Copy to .env and fill in your values.
# Both the server and client load these automatically via python-dotenv.

# --- OIDC Provider (required) ---
OIDC_CONFIG_URL=https://your-domain.auth0.com/.well-known/openid-configuration
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# --- Provider-specific (optional) ---
# Required by Auth0; omit for providers that don't use audience (Google, Keycloak, etc.)
# OIDC_AUDIENCE=https://your-api-identifier

# Set to "true" when the provider issues opaque (non-JWT) access tokens (e.g. GitLab).
# The server will verify the id_token JWT instead.
# OIDC_VERIFY_ID_TOKEN=true

# --- Server ---
BASE_URL=http://localhost:8000
HOST=127.0.0.1
PORT=8000

# --- Client ---
# URL of the MCP server to connect to (default: http://localhost:8000/mcp)
# SERVER_URL=https://your-server.example.com/mcp

# Encryption key for persisting OAuth tokens to disk. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# OAUTH_STORAGE_ENCRYPTION_KEY=
