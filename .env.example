# Copy to .env and fill in your values.
# The server loads these automatically via python-dotenv.

# --- Local dev (HMAC shared secret) ---
JWT_SECRET=dev-secret-change-in-prod-minimum-32b
JWT_ISSUER=http://localhost:8000
JWT_AUDIENCE=mcp-server
HOST=127.0.0.1
PORT=8000

# --- Real OIDC provider (overrides JWT_SECRET when set) ---
# JWKS_URI=https://your-domain.auth0.com/.well-known/jwks.json
# JWT_ISSUER=https://your-domain.auth0.com/
# JWT_AUDIENCE=https://your-api-identifier

# --- GitLab OIDC (used by get_gitlab_token.py) ---
# GITLAB_URL=https://gitlab.example.com
# GITLAB_CLIENT_ID=<Application ID from GitLab OAuth app>
# GITLAB_CLIENT_SECRET=<Secret from GitLab OAuth app>
