+    def _is_verification_token_expired(
+        self, upstream_token_set: UpstreamTokenSet
+    ) -> bool:
+        """Check expiry against the id_token when verify_id_token is enabled.
+
+        GitLab (and some other providers) issue id_tokens with a very short
+        lifetime (e.g. 2 minutes) that is independent of the access token
+        expiry.  The base class checks upstream_token_set.expires_at, which
+        reflects the access token lifetime — so it would never trigger a
+        transparent refresh until the access token itself expires, leaving
+        every request after the id_token TTL returning 401.
+
+        When verify_id_token is True we decode the id_token's exp claim
+        (without re-verifying the signature) and use that for the check.
+        """
+        if self._verify_id_token:
+            id_token = upstream_token_set.raw_token_data.get("id_token")
+            if id_token:
+                try:
+                    import base64
+                    import json
 
+                    parts = id_token.split(".")
+                    if len(parts) >= 2:
+                        padded = parts[1] + "=" * (4 - len(parts[1]) % 4)
+                        payload = json.loads(base64.urlsafe_b64decode(padded))
+                        return float(payload.get("exp", 0)) <= time.time()
+                except Exception:
+                    pass
+            # No id_token available; attempt refresh to be safe.
+            return True
+        return upstream_token_set.expires_at <= time.time()
